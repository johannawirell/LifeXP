{
  "name": "lifexp-backend",
  "private": true,
  "workspaces": [
    "api-gateway",
    "user-service"
  ],
  "scripts": {
    "infra:up": "docker compose -f docker-compose.yml up -d",
    "infra:down": "docker compose -f docker-compose.yml down",
    "dev:api-gateway": "npm --workspace api-gateway run dev",
    "dev:user-service": "npm --workspace user-service run dev",
    "build": "npm --workspace api-gateway run build && npm --workspace user-service run build",
    "prisma:generate": "npm --workspace user-service run prisma:generate",
    "prisma:push": "npm --workspace user-service run prisma:push",
    "seed:user": "npm --workspace user-service run seed"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
