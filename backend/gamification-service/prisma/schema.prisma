generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("GAMIFICATION_DATABASE_URL")
}

model UserGamification {
  id              String          @id @default(uuid())
  userId          String          @unique
  totalXp         Int             @default(0)
  currentLevel    Int             @default(1)
  currentStreak   Int             @default(0)
  bestStreak      Int             @default(0)
  headline        String?
  nextLevelXp     Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  xpEntries       XpEntry[]
  achievements    UserAchievement[]
  focusAreas      FocusArea[]
}

model XpEntry {
  id                 String            @id @default(uuid())
  userGamificationId String
  amount             Int
  sourceType         XpSourceType
  sourceId           String?
  createdAt          DateTime          @default(now())
  userGamification   UserGamification  @relation(fields: [userGamificationId], references: [id], onDelete: Cascade)

  @@index([userGamificationId, createdAt])
}

model AchievementDefinition {
  id            String            @id @default(uuid())
  code          String            @unique
  title         String
  description   String?
  xpReward      Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  userAwards    UserAchievement[]
}

model UserAchievement {
  id                      String                @id @default(uuid())
  userGamificationId      String
  achievementDefinitionId String
  subtitle                String?
  color                   String?
  icon                    String?
  position                Int                   @default(0)
  awardedAt               DateTime              @default(now())
  userGamification        UserGamification      @relation(fields: [userGamificationId], references: [id], onDelete: Cascade)
  achievementDefinition   AchievementDefinition @relation(fields: [achievementDefinitionId], references: [id], onDelete: Cascade)

  @@unique([userGamificationId, achievementDefinitionId])
}

model FocusArea {
  id                 String            @id @default(uuid())
  userGamificationId String
  icon               String
  title              String
  level              Int
  currentXp          Int
  maxXp              Int
  color              String
  position           Int               @default(0)
  userGamification   UserGamification  @relation(fields: [userGamificationId], references: [id], onDelete: Cascade)

  @@index([userGamificationId, position])
}

enum XpSourceType {
  GOAL_CREATED
  GOAL_COMPLETED
  MILESTONE_COMPLETED
  STREAK_REWARD
  ACHIEVEMENT_REWARD
  MANUAL_ADJUSTMENT
}
