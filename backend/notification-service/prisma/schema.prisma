generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NOTIFICATION_DATABASE_URL")
}

model NotificationPreference {
  id                    String   @id @default(uuid())
  userId                String   @unique
  pushEnabled           Boolean  @default(true)
  emailEnabled          Boolean  @default(true)
  streakReminders       Boolean  @default(true)
  goalReminders         Boolean  @default(true)
  weeklyReports         Boolean  @default(true)
  quietHoursStart       String?
  quietHoursEnd         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model NotificationJob {
  id             String                 @id @default(uuid())
  userId         String
  type           NotificationType
  channel        NotificationChannel
  payload        Json
  scheduledFor   DateTime
  status         NotificationJobStatus  @default(PENDING)
  sentAt         DateTime?
  failedAt       DateTime?
  errorMessage   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deliveries     NotificationDelivery[]

  @@index([status, scheduledFor])
  @@index([userId, createdAt])
}

model NotificationDelivery {
  id                String            @id @default(uuid())
  notificationJobId String
  providerMessageId String?
  status            DeliveryStatus    @default(PENDING)
  responsePayload   Json?
  deliveredAt       DateTime?
  createdAt         DateTime          @default(now())
  notificationJob   NotificationJob   @relation(fields: [notificationJobId], references: [id], onDelete: Cascade)

  @@index([notificationJobId])
}

enum NotificationType {
  STREAK_REMINDER
  GOAL_REMINDER
  WEEKLY_REPORT
  SYSTEM_MESSAGE
}

enum NotificationChannel {
  PUSH
  EMAIL
  IN_APP
}

enum NotificationJobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}
