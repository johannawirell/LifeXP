# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service ports
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
USER_SERVICE_URL=http://localhost:3001

# JWT
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Service database URLs
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifexp_auth?schema=public
USER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifexp_user?schema=public
GOALS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifexp_goals?schema=public
ANALYTICS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifexp_analytics?schema=public
GAMIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifexp_gamification?schema=public
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifexp_notification?schema=public
